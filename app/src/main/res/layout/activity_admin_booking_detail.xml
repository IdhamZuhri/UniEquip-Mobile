<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/purple_500"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Booking Details"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Review request and manage status"
            android:textColor="#E1BEE7"
            android:textSize="14sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:padding="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General Information"
                        android:textColor="@color/purple_500"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvAdminBookingInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading info..."
                        android:textColor="#424242"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Requested Equipment"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerAdminBookingItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:background="@android:color/white"
                android:minHeight="100dp"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actions"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btnAdminApprove"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Approve Request"
                    android:backgroundTint="#4CAF50"
                    android:textColor="@android:color/white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnAdminReject"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Reject Request"
                    android:backgroundTint="#F44336"
                    android:textColor="@android:color/white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status Updates"
                    android:textColor="#757575"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"
                    android:layout_marginStart="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btnAdminBorrowed"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="50dp"
                        android:text="Mark Borrowed"
                        android:backgroundTint="#2196F3"
                        android:textAllCaps="false"
                        app:cornerRadius="10dp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnAdminReturned"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="50dp"
                        android:text="Mark Returned"
                        android:backgroundTint="#FF9800"
                        android:textAllCaps="false"
                        app:cornerRadius="10dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Cancel / Go Back"
                    android:textColor="@android:color/black"
                    android:backgroundTint="#E0E0E0"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>